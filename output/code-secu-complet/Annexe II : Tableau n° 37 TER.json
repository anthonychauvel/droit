    "texte": "CANCERS PROVOQUES PAR LES OPERATIONS DE GRILLAGE DES MATTES DE NICKEL DÉSIGNATION DE LA MALADIE DÉLAI de prise en charge LISTE LIMITATIVE DES TRAVAUX SUSCEPTIBLES de provoquer ces maladies Cancer primitif de l'ethmoïde et des sinus de la face. 40 ans Opérations de grillage de mattes de nickel. Cancer bronchique primitif.",
    "texteHtml": "<p align=\"center\"><strong><br/>CANCERS PROVOQUES PAR LES OPERATIONS DE GRILLAGE DES MATTES DE NICKEL</strong></p><p></p><p></p><p><br/><br/><br/></p><table border=\"1\" cellSpacing=\"0\" width=\"605\" align=\"center\" cellPadding=\"0\"><tbody><tr><td width=\"246\"><p align=\"center\">DÉSIGNATION DE LA MALADIE</p></td><td width=\"76\"><p align=\"center\">DÉLAI de prise en charge</p></td><td width=\"284\"><p align=\"center\">LISTE LIMITATIVE DES TRAVAUX SUSCEPTIBLES de provoquer ces maladies</p></td></tr><tr><td width=\"246\" vAlign=\"top\"><p>Cancer primitif de l'ethmoïde et des sinus de la face.</p></td><td width=\"76\" vAlign=\"top\"><p align=\"center\">40 ans</p></td><td width=\"284\" vAlign=\"top\"><p>Opérations de grillage de mattes de nickel.</p></td></tr><tr><td width=\"246\" vAlign=\"top\"><p>Cancer bronchique primitif.</p></td><td width=\"76\" vAlign=\"top\"><p align=\"center\"></p></td><td width=\"284\" vAlign=\"top\"></td></tr></tbody></table>",
